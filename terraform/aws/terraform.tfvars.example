# Copy to terraform.tfvars and fill in values before apply.
# cp terraform.tfvars.example terraform.tfvars

aws_region = "ca-central-1"

# Required: EC2 key pair must exist in the target region.
ec2_key_name = "your-key-pair-name"

# t3.xlarge (16 GB RAM) recommended for llama3.2:3b on CPU.
instance_type       = "t3.xlarge"
root_volume_size_gb = 100

# Restrict inbound access in non-lab environments.
allowed_ssh_cidr     = ["203.0.113.10/32"]
allowed_gateway_cidr = ["203.0.113.10/32"]

# Pinned runtime dependencies (see dependencies.lock.json)
openclaw_npm_package = "openclaw@2026.6.1"
openclaw_version     = "2026.6.1"
node_version         = "24.10.0"
ollama_version       = "0.30.5"

install_ollama = true
ollama_model   = "llama3.2:3b"
